<UserControl x:Class="AssetEditor.Views.Settings.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:System="clr-namespace:System;assembly=mscorlib" 
             xmlns:gameinfo="clr-namespace:Shared.Core.Services;assembly=Shared.Core" 
             xmlns:behaviors="clr-namespace:Shared.Ui.Common.Behaviors;assembly=Shared.Ui"
             xmlns:loc="clr-namespace:Shared.Ui.Common;assembly=Shared.Ui"
             xmlns:local="clr-namespace:AssetEditor.Views.Settings" xmlns:viewmodels="clr-namespace:AssetEditor.ViewModels" 
             d:DataContext="{d:DesignInstance Type=viewmodels:SettingsViewModel}"
             mc:Ignorable="d" >

    <UserControl.Resources>
        <ObjectDataProvider x:Key="GameTypeEnums" MethodName="GetValues" ObjectType="{x:Type System:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="gameinfo:GameTypeEnum"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>

        <local:SettingsEnumConverter x:Key="SettingsEnumConverter"/>
        <local:FontWeightNameConverter x:Key="FontWeightNameConverter"/>
        <DataTemplate x:Key="SettingsEnumConverterTemplate">
            <TextBlock Text="{Binding Converter={StaticResource SettingsEnumConverter}}"/>
        </DataTemplate>
        <DataTemplate x:Key="FontWeightTemplate">
            <TextBlock Text="{Binding Converter={StaticResource FontWeightNameConverter}}"/>
        </DataTemplate>
    </UserControl.Resources>

    <Grid Height="Auto" Width="Auto" Margin="5,0,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="230"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="{loc:Loc SettingsWindow.Application}" Margin="5, 10, 0, 0" FontSize="15"/>
            <Separator Grid.Row="1" Grid.ColumnSpan="3" Height="1" Margin="5, 5, 10, 10"/>

            <TextBlock Grid.Row="2" Text="{loc:Loc SettingsWindow.SelectedLanguage}" Margin="5, 0, 0, 0"/>
            <ComboBox Grid.Row="2" Grid.Column="1" Margin="0, 0, 0, 5" SelectedItem="{Binding SelectedLanguage, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                      ItemsSource="{Binding AvailableLangauges}" ItemTemplate="{StaticResource SettingsEnumConverterTemplate}"/>

            <TextBlock Grid.Row="3" Text="{loc:Loc SettingsWindow.Theme}" Margin="5, 0, 0, 0"/>
            <ComboBox Grid.Row="3" Grid.Column="1" Margin="0, 0, 0, 5" SelectedItem="{Binding CurrentTheme, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                      ItemsSource="{Binding AvailableThemes}" ItemTemplate="{StaticResource SettingsEnumConverterTemplate}"/>

            <TextBlock Grid.Row="4" Text="{loc:Loc SettingsWindow.Font}" Margin="5, 0, 0, 0"/>
            <ComboBox Grid.Row="4" Grid.Column="1" Margin="0, 0, 0, 5" SelectedItem="{Binding SelectedFont, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                      ItemsSource="{Binding AvailableFonts}" ItemTemplate="{StaticResource SettingsEnumConverterTemplate}"/>

            <TextBlock Grid.Row="5" Text="{loc:Loc SettingsWindow.FontWeight}" Margin="5, 0, 0, 0"/>
            <ComboBox Grid.Row="5" Grid.Column="1" Margin="0, 0, 0, 5" SelectedItem="{Binding SelectedFontWeight, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                      ItemsSource="{Binding AvailableFontWeights}" ItemTemplate="{StaticResource FontWeightTemplate}"/>

            <TextBlock Grid.Row="6" Grid.Column="0" Text="{loc:Loc SettingsWindow.StartMaximised}" Margin="5, 0, 0, 0"/>
            <CheckBox Grid.Row="6" Grid.Column="1" Margin="-1, 0, 0, 5" IsChecked="{Binding StartMaximised, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"/>

            <TextBlock Grid.Row="7" Grid.Column="0"  Text="{loc:Loc SettingsWindow.SelectedGame}" Margin="5, 0, 0, 0"/>
            <ComboBox Grid.Row="7" Grid.Column="1" Width="150" Margin="0, 0, 0, 5" SelectedItem="{Binding CurrentGame, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                      ItemsSource="{Binding Games}" ItemTemplate="{StaticResource SettingsEnumConverterTemplate}"/>

            <TextBlock Grid.Row="8" Grid.Column="0" Text="{loc:Loc SettingsWindow.LoadGameFileOnStartup}" Margin="5, 0, 0, 0"/>
            <CheckBox Grid.Row="8" Grid.Column="1" Margin="-1, 0, 0, 5" IsChecked="{Binding LoadCaPacksByDefault, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"/>

            <TextBlock Grid.Row="9" Grid.Column="0" Text="{loc:Loc SettingsWindow.ShowCaWems}" Margin="5, 0, 0, 0"/>
            <CheckBox Grid.Row="9" Grid.Column="1" Margin="-1, 0, 0, 5" IsChecked="{Binding ShowCAWemFiles, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"/>
        </Grid>



        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="230"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="{loc:Loc SettingsWindow.Rendering}" Margin="5, 10, 0, 0" FontSize="15"/>
            <Separator Grid.Row="1" Grid.ColumnSpan="3" Height="1" Margin="5, 5, 10, 10"/>

            <TextBlock Grid.Row="2" Grid.Column="0" Text="{loc:Loc SettingsWindow.RenderBackground}" Margin="5, 0, 0, 0"/>
            <ComboBox Grid.Row="2" Grid.Column="1" Margin="0, 0, 0, 5" SelectedItem="{Binding CurrentRenderEngineBackgroundColour, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                      ItemsSource="{Binding RenderEngineBackgroundColours}" ItemTemplate="{StaticResource SettingsEnumConverterTemplate}"/>

            <StackPanel Grid.Row="3" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="5,0,0,5">
                <TextBlock Text="R:" VerticalAlignment="Center" Margin="0,0,3,0"/>
                <TextBox Text="{Binding CustomBackgroundR, UpdateSourceTrigger=PropertyChanged}" Width="40" VerticalContentAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="G:" VerticalAlignment="Center" Margin="0,0,3,0"/>
                <TextBox Text="{Binding CustomBackgroundG, UpdateSourceTrigger=PropertyChanged}" Width="40" VerticalContentAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="B:" VerticalAlignment="Center" Margin="0,0,3,0"/>
                <TextBox Text="{Binding CustomBackgroundB, UpdateSourceTrigger=PropertyChanged}" Width="40" VerticalContentAlignment="Center" Margin="0,0,8,0"/>
            </StackPanel>

            <TextBlock Grid.Row="4" Grid.Column="0" Text="{loc:Loc SettingsWindow.OnlyLoadLod0}" Margin="5, 0, 0, 0" ToolTip="When importing a reference mesh in the Kitbash tool, only import Lod0 in order to save memory."/>
            <CheckBox Grid.Row="4" Grid.Column="1" Margin="-1, 0, 0, 5" IsChecked="{Binding OnlyLoadLod0ForReferenceMeshes, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" />

            <TextBlock Grid.Row="5" Grid.Column="0" Text="{loc:Loc SettingsWindow.GridSize}" Margin="5, 0, 0, 0" ToolTip="Size of the grid in visual editors"/>
            <TextBox  Grid.Row="5" Grid.Column="1" Text="{Binding VisualEditorsGridSize, UpdateSourceTrigger=LostFocus}" MaxLength="4" Width="150" Margin="0, 0, 0, 5" HorizontalAlignment="Left" HorizontalContentAlignment="Right"/>



        </Grid>

        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="{loc:Loc SettingsWindow.GameFiles}" Margin="5, 10, 0, 0" FontSize="15"/>
            <Separator Grid.Row="1" Height="1" Margin="5, 5, 10, 10"/>

            <ItemsControl Grid.Row="5" ItemsSource="{Binding GameDirectores}" >
                <ItemsControl.ItemContainerStyle>
                    <Style TargetType="ContentPresenter">
                        <Setter Property="VerticalAlignment" Value="Stretch" />
                        <Setter Property="HorizontalAlignment" Value="Stretch" />
                    </Style >
                </ItemsControl.ItemContainerStyle>

                <ItemsControl.ItemTemplate >
                    <DataTemplate>
                        <Grid Margin="0, 0, 0, 5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="600"/>
                                <ColumnDefinition Width="40"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="{Binding GameName}" Margin="5, 0, 0, 0"/>
                            <TextBox Grid.Column="1"
                                        Style="{StaticResource HintedTextBox}"                                     
                                        Text="{Binding Path}" 
                                        Tag='Browse for game data location e.g. "C:\SteamLibrary\steamapps\common\Total War WARHAMMER III\data"'
                                        IsReadOnly="True"
                                        Padding="2.5, 0, 0, 0"/>
                            <Button Grid.Column="2" Content="..." Command="{Binding BrowseCommand}" Margin="5, 0, 5, 0"/>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="605"/>
                <ColumnDefinition Width="40"/>
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="{loc:Loc SettingsWindow.AudioModding}" Margin="5, 5, 0, 0" FontSize="15"/>
            <Separator Grid.Row="1" Grid.ColumnSpan="3" Height="1" Margin="5, 5, 10, 10"/>

            <TextBlock Grid.Row="2" Grid.Column="0" Text="{loc:Loc SettingsWindow.WwiseCli}" Margin="5, 0, 0, 0"/>
            <TextBox Grid.Row="2" Grid.Column="1" Style="{StaticResource HintedTextBox}" Text="{Binding WwisePath}" 
                     Tag='e.g. "C:\Program Files (x86)\Audiokinetic\Wwise2019.2.15.7667\Authoring\x64\Release\bin\WwiseCLI.exe"' IsReadOnly="True" Margin="0, 0, 5, 5" Padding="2.5, 0, 0, 0"/>
            <Button Grid.Row="2" Grid.Column="2" Content="..." Command="{Binding BrowseCommand}" Margin="0, 0, 10, 5"/>
        </Grid>

        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="230"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="{loc:Loc SettingsWindow.AutoSaveAndBackup}" Margin="5, 5, 0, 0" FontSize="15"/>
            <Separator Grid.Row="1" Grid.ColumnSpan="3" Height="1" Margin="5, 5, 10, 10"/>

            <TextBlock Grid.Row="2" Grid.Column="0" Text="{loc:Loc SettingsWindow.EnableAutoSave}" Margin="5, 0, 0, 0"/>
            <CheckBox Grid.Row="2" Grid.Column="1" Margin="-1, 0, 0, 5" IsChecked="{Binding EnableAutoSave, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"/>

            <TextBlock Grid.Row="3" Grid.Column="0" Text="{loc:Loc SettingsWindow.AutoSaveInterval}" Margin="5, 0, 0, 0"/>
            <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal">
                <TextBox Text="{Binding AutoSaveIntervalMinutes, UpdateSourceTrigger=LostFocus}" MaxLength="3" Width="60" VerticalContentAlignment="Center" HorizontalAlignment="Left" HorizontalContentAlignment="Right" Margin="0, 0, 0, 5"/>
                <TextBlock Text="{loc:Loc SettingsWindow.Minutes}" VerticalAlignment="Center" Margin="5, 0, 0, 0"/>
            </StackPanel>

            <TextBlock Grid.Row="4" Grid.Column="0" Text="{loc:Loc SettingsWindow.BackupPath}" Margin="5, 0, 0, 0"/>
            <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding BackupPath, UpdateSourceTrigger=PropertyChanged}" Width="400" VerticalContentAlignment="Center" IsReadOnly="True" HorizontalAlignment="Left" Margin="0, 0, 5, 5" Padding="2.5, 0, 0, 0"/>
            <Button Grid.Row="4" Grid.Column="2" Content="..." Command="{Binding BrowseBackupPathCommand}" Margin="0, 0, 10, 5"/>

            <TextBlock Grid.Row="5" Grid.Column="0" Text="{loc:Loc SettingsWindow.MaxBackupCount}" Margin="5, 0, 0, 0"/>
            <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding MaxBackupCount, UpdateSourceTrigger=LostFocus}" MaxLength="3" Width="60" VerticalContentAlignment="Center" HorizontalAlignment="Left" HorizontalContentAlignment="Right" Margin="0, 0, 0, 5"/>

            <TextBlock Grid.Row="6" Grid.Column="0" Text="{loc:Loc SettingsWindow.UseZstdCompression}" Margin="5, 0, 0, 0"/>
            <CheckBox Grid.Row="6" Grid.Column="1" Margin="-1, 0, 0, 5" IsChecked="{Binding UseZstdCompression, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"/>
        </Grid>
    </Grid>
</UserControl>