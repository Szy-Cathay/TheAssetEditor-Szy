<Window x:Class="AssetEditor.Views.Settings.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AssetEditor.Views.Settings"
          xmlns:loc="clr-namespace:Shared.Ui.Common;assembly=Shared.Ui"
        mc:Ignorable="d"
        Title="{loc:Loc SettingsWindow.Title}" Height="750" Width="850" MinHeight="600" MinWidth="700"
        ResizeMode="CanResize" FontFamily="{DynamicResource AppFontFamily}" Background="{DynamicResource WindowBackground}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <local:SettingsView />
        </ScrollViewer>
        <Button Grid.Row="1" Content="{loc:Loc SettingsWindow.SaveButton}" Width="75" Margin="2, 10, 8, 2" HorizontalAlignment="Right" VerticalAlignment="Bottom" Command="{Binding SaveCommand}"  Click="Button_Click"/>
    </Grid>

</Window>